<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="false" scanPeriod="30 seconds">

    <!-- APPENDERS -->
    <appender name="peer" class="io.quasient.pal.common.logging.PeerFileAppender">
        <file>logs/peer.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="kafka" class="io.quasient.pal.common.logging.PeerFileAppender">
        <file>logs/kafka.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <appender name="etcd" class="io.quasient.pal.common.logging.PeerFileAppender">
        <file>logs/etcd.log</file>
        <encoder>
            <pattern>%date %level [%thread][%logger{10}] %message%n</pattern>
        </encoder>
    </appender>

    <!-- LOGGERS -->
    <logger name="io.quasient.pal.core" level="info" additivity="false">
        <appender-ref ref="peer"/>
    </logger>

    <logger name="io.quasient.pal.common" level="info" additivity="false">
        <appender-ref ref="peer"/>
    </logger>

    <logger name="io.quasient.pal.cxn" level="info" additivity="false">
        <appender-ref ref="peer"/>
    </logger>

    <logger name="io.quasient.pal.shd.apache.kafka" level="info" additivity="false">
        <appender-ref ref="kafka"/>
    </logger>

    <logger name="io.quasient.pal.shd.io.etcd" level="info" additivity="false">
        <appender-ref ref="etcd"/>
    </logger>

    <root level="info">
        <appender-ref ref="peer"/>
    </root>

</configuration>
